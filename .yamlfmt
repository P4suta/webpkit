# yamlfmt: YAML formatter configuration.
# https://github.com/google/yamlfmt/blob/main/docs/config-file.md

formatter:
  type: basic
  indent: 2
  retain_line_breaks_single: true
  scan_folded_as_literal: true
  trim_trailing_whitespace: true
  eof_newline: true
  line_ending: lf
  pad_line_comments: 1
  max_line_length: 0

include:
  - "**/*.yml"
  - "**/*.yaml"

exclude:
  - "target/**"
  - "artifacts/**"
  - "node_modules/**"
