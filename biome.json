{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "json": {
    "formatter": {
      "enabled": true,
      "trailingCommas": "none"
    }
  },
  "files": {
    "includes": [
      "**/*.json",
      "**/*.jsonc",
      "!target/**",
      "!node_modules/**",
      "!artifacts/**",
      "!package-lock.json",
      "!mutants.out/**",
      "!mutants.out.old/**",
      "!mutants-*/**"
    ]
  },
  "linter": { "enabled": false }
}
