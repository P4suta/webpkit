.ie \n(.g .ds Aq \(aq
.el .ds Aq '
.TH webp-completions 1  "completions " 
.SH NAME
completions \- Print a shell completion script
.SH SYNOPSIS
\fBcompletions\fR [\fB\-h\fR|\fB\-\-help\fR] <\fISHELL\fR> 
.SH DESCRIPTION
Print a shell completion script.
.PP
The script is generated from the same command tree that parses your arguments, so it cannot describe a flag that does not exist.
.PP
Load it for the current shell, or install it where your shell looks:
.PP
bash:        eval "$(webp completions bash)" zsh:         webp completions zsh > ~/.zfunc/_webp fish:        webp completions fish > ~/.config/fish/completions/webp.fish powershell:  webp completions powershell | Out\-String | Invoke\-Expression
.SH OPTIONS
.TP
\fB\-h\fR, \fB\-\-help\fR
Print help (see a summary with \*(Aq\-h\*(Aq)
.TP
<\fISHELL\fR>
The shell to generate for
.br

.br
\fIPossible values:\fR
.RS 14
.IP \(bu 2
bash
.IP \(bu 2
elvish
.IP \(bu 2
fish
.IP \(bu 2
powershell
.IP \(bu 2
zsh
.RE
